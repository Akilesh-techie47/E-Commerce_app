# Rename this file to .env and fill in your real values
# NEVER commit your actual .env file to GitHub

# MongoDB connection string
# - Local MongoDB: mongodb://127.0.0.1:27017/ecommerce
# - MongoDB Atlas: mongodb+srv://<username>:<password>@cluster.mongodb.net/ecommerce
MONGO_URI=mongodb://127.0.0.1:27017/ecommerce

# Port the backend server runs on
PORT=5000

# Secret key used to sign JWT auth tokens (use a long random string)
JWT_SECRET=your_jwt_secret_key_here
